{
  "name": "skoun",
  "version": "1.0.0",
  "private": true,
  "description": "Sakan Lebanon — monorepo (Expo mobile app + Express API)",
  "scripts": {
    "dev:frontend": "npm --prefix frontend start",
    "dev:backend": "npm --prefix backend run dev",
    "build:backend": "npm --prefix backend run build",
    "db:generate": "npm --prefix backend run db:generate",
    "db:push": "npm --prefix backend run db:push",
    "db:studio": "npm --prefix backend run db:studio",
    "install:all": "npm --prefix frontend install && npm --prefix backend install"
  },
  "engines": {
    "node": ">=20"
  }
}

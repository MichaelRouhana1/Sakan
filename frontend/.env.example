# Use your PC's LAN IP when testing on a physical phone (not localhost).
# Must match backend PUBLIC_BASE_URL so listing photo URLs load on device.
EXPO_PUBLIC_API_URL=http://192.168.x.x:3001

# Maps: Expo Go uses Apple Maps (iOS) / Expo's Google key (Android).
# For a custom Android build, set a Google Maps API key in app.json:
#   android.config.googleMaps.apiKey
# Optional: EXPO_PUBLIC_GOOGLE_MAPS_API_KEY if you wire it into app.config.js later.
